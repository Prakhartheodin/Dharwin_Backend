{
  "name": "node-template-server",
  "version": "1.0.0",
  "description": "Its an backend server template ",
  "main": "src/index.js",
  "author": "Akshay Pareek",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "test": "node --test ./src/services/emailConnectionPolicy.service.test.js ./src/services/auth.verifyEmailUpdate.test.js",
    "ensure:sales-agent-role": "node ./scripts/ensure-sales-agent-role.js",
    "audit:ci": "npm audit --audit-level=high",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check **/*.js",
    "prettier:fix": "prettier --write **/*.js",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "prepare": "node -e \"if(process.env.NODE_ENV !== 'production') require('husky').install()\"",
    "docker:livekit": "docker compose -f docker-compose.livekit-local.yml up -d",
    "docker:livekit:down": "docker compose -f docker-compose.livekit-local.yml down",
    "docker:livekit:full": "docker compose -f livekit/docker-compose.yml up -d",
    "docker:livekit:full:down": "docker compose -f livekit/docker-compose.yml down"
  },
  "keywords": [
    "node",
    "node.js",
    "boilerplate",
    "generator",
    "express",
    "rest",
    "api",
    "mongodb",
    "mongoose",
    "es6",
    "es7",
    "es8",
    "es9",
    "travis",
    "docker",
    "passport",
    "joi",
    "eslint",
    "prettier"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1031.0",
    "@aws-sdk/s3-request-presigner": "^3.1031.0",
    "@azure/msal-node": "^5.1.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@pinecone-database/pinecone": "^7.2.0",
    "@smithy/node-http-handler": "^4.6.1",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-mongo-sanitize": "^2.0.0",
    "express-rate-limit": "^5.0.0",
    "geoip-lite": "^1.4.10",
    "googleapis": "^171.4.0",
    "gpt-tokenizer": "^3.4.0",
    "helmet": "^7.1.0",
    "http-status": "^1.4.0",
    "joi": "^17.3.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "livekit-server-sdk": "^2.15.0",
    "mammoth": "^1.11.0",
    "mongodb": "^6.21.0",
    "mongoose": "^8.0.0",
    "morgan": "^1.9.1",
    "multer": "^1.4.5-lts.1",
    "music-metadata": "^11.12.3",
    "nodemailer": "^6.3.1",
    "openai": "^4.104.0",
    "passport": "^0.4.0",
    "passport-jwt": "^4.0.0",
    "pdf-parse": "^2.4.5",
    "pm2": "^6.0.14",
    "socket.io": "^4.7.0",
    "swagger-jsdoc": "^6.0.8",
    "swagger-ui-express": "^4.1.6",
    "validator": "^13.0.0",
    "winston": "^3.2.1",
    "xlsx": "^0.18.5",
    "xss-clean": "^0.1.4"
  },
  "overrides": {
    "basic-ftp": "5.3.0"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/express-rate-limit": "^5.1.3",
    "eslint": "^7.0.0",
    "eslint-config-airbnb-base": "^14.0.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-import": "^2.18.2",
    "eslint-plugin-prettier": "^3.1.1",
    "eslint-plugin-security": "^1.4.0",
    "husky": "7.0.4",
    "lint-staged": "^11.0.0",
    "nodemon": "^2.0.0",
    "prettier": "^2.0.5"
  },
  "type": "module"
}

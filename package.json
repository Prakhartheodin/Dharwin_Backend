{
  "name": "node-template-server",
  "version": "1.0.0",
  "description": "Its an backend server template ",
  "bin": "bin/createNodejsApp.js",
  "main": "src/index.js",
  "author": "Akshay Pareek",
  "engines": {
    "node": ">=12.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check **/*.js",
    "prettier:fix": "prettier --write **/*.js",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "prepare": "husky install",
    "seed:offers": "node scripts/seed-offers-placements.js",
    "seed:managers": "node scripts/seed-managers.js",
    "seed:preboarding": "node scripts/seed-preboarding.js",
    "seed:candidate-role": "node scripts/seed-candidate-role.js",
    "seed:recruiter-role": "node scripts/seed-recruiter-role.js",
    "clean:import": "node scripts/clean-and-import-db.js",
    "cleanup:offers-placements": "node scripts/cleanup-offers-placements.js",
    "simulate:email-links": "node scripts/simulate-email-links.mjs",
    "docker:livekit": "docker compose -f docker-compose.livekit-local.yml up -d",
    "docker:livekit:down": "docker compose -f docker-compose.livekit-local.yml down",
    "docker:livekit:full": "docker compose -f livekit/docker-compose.yml up -d",
    "docker:livekit:full:down": "docker compose -f livekit/docker-compose.yml down",
    "provision:platform-super": "node scripts/provision-platform-super-user.js",
    "verify:permissions": "node scripts/verify-permission-aliases.mjs"
  },
  "keywords": [
    "node",
    "node.js",
    "boilerplate",
    "generator",
    "express",
    "rest",
    "api",
    "mongodb",
    "mongoose",
    "es6",
    "es7",
    "es8",
    "es9",
    "travis",
    "docker",
    "passport",
    "joi",
    "eslint",
    "prettier"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.744.0",
    "@aws-sdk/s3-request-presigner": "^3.744.0",
    "@azure/msal-node": "^5.1.0",
    "@google/generative-ai": "^0.24.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-mongo-sanitize": "^2.0.0",
    "express-rate-limit": "^5.0.0",
    "geoip-lite": "^1.4.10",
    "googleapis": "^171.4.0",
    "helmet": "^4.1.0",
    "http-status": "^1.4.0",
    "joi": "^17.3.0",
    "jsonwebtoken": "^8.5.1",
    "jszip": "^3.10.1",
    "livekit-server-sdk": "^2.15.0",
    "mammoth": "^1.11.0",
    "moment": "^2.24.0",
    "mongodb": "^6.21.0",
    "mongoose": "^8.0.0",
    "morgan": "^1.9.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.3.1",
    "openai": "^4.104.0",
    "passport": "^0.4.0",
    "passport-jwt": "^4.0.0",
    "pdf-parse": "^2.4.5",
    "pm2": "^5.1.0",
    "socket.io": "^4.7.0",
    "swagger-jsdoc": "^6.0.8",
    "swagger-ui-express": "^4.1.6",
    "validator": "^13.0.0",
    "winston": "^3.2.1",
    "xlsx": "^0.18.5",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/express-rate-limit": "^5.1.3",
    "eslint": "^7.0.0",
    "eslint-config-airbnb-base": "^14.0.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-import": "^2.18.2",
    "eslint-plugin-prettier": "^3.1.1",
    "eslint-plugin-security": "^1.4.0",
    "husky": "7.0.4",
    "lint-staged": "^11.0.0",
    "nodemon": "^2.0.0",
    "prettier": "^2.0.5"
  },
  "type": "module"
}

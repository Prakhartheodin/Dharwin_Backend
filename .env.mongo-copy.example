# Optional overrides for mongo copy / verify scripts (do not commit real secrets).
# Copy lines into .env or export in the shell before npm run.

# MONGO_SOURCE_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/your-db-name
# MONGO_TARGET_URI=mongodb://127.0.0.1:27017
# MONGO_DB_NAME=your-db-name
# MONGO_COPY_DRY_RUN=1
# MONGO_COPY_BATCH=1000

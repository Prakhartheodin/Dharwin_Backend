NODE_ENV=development

# Port number
PORT=3000

# Reverse proxy hops for Express req.ip (platform audit IP, rate limits). 0 = direct Node (local dev). AWS: usually 1 behind a single ALB; 2 if CloudFront (or another proxy) sits in front of ALB—match your real hop count.
# TRUST_PROXY_HOPS=0
# Optional: TRUST_PROXY=true enables app.set('trust proxy', true) when hops=0. Prefer TRUST_PROXY_HOPS=1 behind one nginx/ALB.
# Nginx: proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
# TRUST_PROXY=true

# Max JSON body size for Express (e.g. PM task-breakdown/apply with many long descriptions). Default in app.js is 2mb if unset.
# JSON_BODY_LIMIT=2mb

# URL of the Mongo DB
MONGODB_URL=mongodb://127.0.0.1:27017/node-boilerplate

# JWT
# JWT secret key
JWT_SECRET=thisisasamplesecret
# Number of minutes after which an access token expires
JWT_ACCESS_EXPIRATION_MINUTES=30
# Number of days after which a refresh token expires
JWT_REFRESH_EXPIRATION_DAYS=30
# Number of minutes after which a reset password token expires
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
# Number of minutes after which a verify email token expires
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# SMTP configuration options for the email service
# For testing, you can use a fake SMTP service like Ethereal: https://ethereal.email/create
SMTP_HOST=email-server
SMTP_PORT=587
SMTP_USERNAME=email-server-username
SMTP_PASSWORD=email-server-password
EMAIL_FROM=support@yourapp.com

# ========== REQUIRED FOR DEPLOYMENT - Email/Share Links ==========
# Without these, all emails and share links will contain localhost URLs.
# See DEPLOYMENT_URLS.md in project root for full guide.

# Frontend base URL (reset-password, verify-email, sign-in, onboarding links in emails)
# Production: https://dharwinone.com
FRONTEND_BASE_URL=http://localhost:3001
# FRONTEND_BASE_URL=https://dharwinone.com

# Backend public URL (share links, document downloads, webhooks)
# Production: https://apis.yourdomain.com
# BACKEND_PUBLIC_URL=http://localhost:3000
# BACKEND_PUBLIC_URL=https://apis.dharwinone.com

# LiveKit Configuration
# --- Option A: Local Docker ---
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=devsecret123456789012345678901234
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin123
# MINIO_BUCKET=recordings

# --- Option B: LiveKit Cloud (no Docker) ---
LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
LIVEKIT_API_KEY=your_api_key_from_cloud_project
LIVEKIT_API_SECRET=your_api_secret_from_cloud_project
# Recordings: use AWS S3 (set AWS credentials and bucket below)
LIVEKIT_S3_BUCKET=recordings

# MinIO (only for Option A)
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin123
# MINIO_BUCKET=recordings

# OpenAI – blog AI, module generation, and DALL-E cover images
OPENAI_API_KEY=

# PM assistant (GPT task breakdown + assignment runs). Enabled when OPENAI_API_KEY is set, or set PM_ASSISTANT_ENABLED=true.
# Opt out: PM_ASSISTANT_ENABLED=false
# Optional overrides (defaults: gpt-4o-mini / gpt-4o):
# PM_OPENAI_MODEL=gpt-4o-mini
# PM_OPENAI_MODEL_ESCALATION=gpt-4o

# GCP (YouTube + Gmail OAuth)
GCP_YOUTUBE_API_KEY=
GCP_GOOGLE_CLIENT_ID=
GCP_GOOGLE_CLIENT_SECRET=
GCP_GOOGLE_REDIRECT_URI=http://localhost:3000/v1/email/auth/google/callback

# Microsoft Outlook (Graph API) — Azure Portal > App registrations
# Redirect URI (Web): {BACKEND_PUBLIC_URL}/v1/email/auth/microsoft/callback
# Delegated permissions: Mail.ReadWrite, Mail.Send, User.Read (+ admin consent if org)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Must match Azure "Redirect URI" exactly (path + port). Legacy /email/... still works.
MICROSOFT_REDIRECT_URI=http://localhost:3001/v1/email/auth/microsoft/callback
MICROSOFT_TENANT_ID=common
# Set to 1 to log raw Graph inbox probe on each listThreads (see server stderr)
# OUTLOOK_DEBUG_GRAPH=1

# Attendance — max hours counted/stored for a single punch session (prevents 200h+ calendar cells from forgotten punch-out / import bugs). Default 24.
# ATTENDANCE_MAX_SESSION_HOURS=24
# Max hours summed per calendar day across multiple punch sessions (prevents 24h+24h=48h when capped sessions stack). Default 24 wall-clock hours.
# ATTENDANCE_MAX_HOURS_PER_CALENDAR_DAY=24

# Bolna Calling Configuration
# API key from Bolna dashboard
BOLNA_API_KEY=
# Job posting / recruiter verification (no in-app prompt PATCH — use Bolna dashboard prompt for this agent)
BOLNA_AGENT_ID=
# Applicant verification after apply (app PATCHes system prompt before each call). MUST differ from BOLNA_AGENT_ID or both flows break.
BOLNA_CANDIDATE_AGENT_ID=
# Caller ID used for outbound calls (E.164 format, e.g. +18336990430)
BOLNA_FROM_PHONE_NUMBER=
# Optional fallback for caller ID (AddOn compatibility)
CALLER_ID=
# Bolna API base URL
BOLNA_API_BASE=https://api.bolna.ai
# Max call length in seconds (900 = 15 min). Sent on POST /call as max_call_duration_seconds when > 0.
# If calls still drop after ~90–120s, raise "Total Call Timeout" in Bolna → each agent → Call tab (dashboard limit often overrides or caps API).
# Set 0 to omit max_call_duration_seconds (then only the Bolna Call tab applies).
BOLNA_MAX_CALL_DURATION_SECONDS=900

# ========== Voice agent knowledge base (RAG) ==========
# Requires OPENAI_API_KEY for embeddings + query. Tune KB_MIN_SIMILARITY on real data (e.g. 0.25–0.35).
KB_EMBEDDING_MODEL=text-embedding-3-small
# Optional: truncate embedding dimensions (256–3072). Leave unset or empty for model default.
# KB_EMBEDDING_DIMENSIONS=
KB_CHUNK_TARGET_TOKENS=768
KB_CHUNK_OVERLAP_TOKENS=128
KB_TOP_K=8
KB_MIN_SIMILARITY=0.28
KB_MAX_PDF_MB=25
KB_MAX_URL_BYTES=2097152
KB_MAX_DOCS_PER_AGENT=50
KB_QUERY_CACHE_TTL_SECONDS=3600
KB_QUERY_CACHE_MISS_TTL_SECONDS=120
MONGODB_VECTOR_SEARCH_ENABLED=false

# ========== Bolna hosted Knowledge Base sync (optional) ==========
# When true, PDF + URL ingests also call Bolna POST /knowledgebase (same BOLNA_API_KEY). Attach RAG IDs in Bolna → Agent → LLM → knowledge bases.
KB_BOLNA_SYNC_ENABLED=true
KB_BOLNA_KB_MULTILINGUAL=false
KB_BOLNA_KB_CHUNK_SIZE=512
KB_BOLNA_KB_OVERLAPPING=128
KB_BOLNA_KB_SIMILARITY_TOP_K=15

# RapidAPI key for External Jobs (Active Jobs DB / LinkedIn Jobs API)
RAPIDAPI_KEY=

# Comma-separated emails allowed to use Activity Logs API/UI and support camera invites. When unset, defaults to harvinder@superadmin.in.
# DESIGNATED_SUPERADMIN_EMAILS=harvinder@superadmin.in

# ========== HRM WebRTC (Windows agent + SignalR) ==========
# Mint admin JWTs for the hrm-webrtc/backend hub. Values must match that service's Jwt:Key, Jwt:Issuer, Jwt:Audience (see hrm-webrtc/backend/Program.cs).
# HRM_WEBRTC_JWT_SECRET=
# HRM_WEBRTC_JWT_ISSUER=
# HRM_WEBRTC_JWT_AUDIENCE=
# Base URL of the HRM backend (no trailing slash). Returned to the browser for SignalR; optional if NEXT_PUBLIC_HRM_WEBRTC_BACKEND_URL is set on the frontend.
# HRM_WEBRTC_SIGNALING_BASE_URL=https://your-hrm-backend.example.com
# HRM_WEBRTC_TOKEN_EXPIRATION_MINUTES=15

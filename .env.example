NODE_ENV=development

# Port number
PORT=3000

# URL of the Mongo DB
MONGODB_URL=mongodb://127.0.0.1:27017/node-boilerplate

# JWT
# JWT secret key
JWT_SECRET=thisisasamplesecret
# Number of minutes after which an access token expires
JWT_ACCESS_EXPIRATION_MINUTES=30
# Number of days after which a refresh token expires
JWT_REFRESH_EXPIRATION_DAYS=30
# Number of minutes after which a reset password token expires
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
# Number of minutes after which a verify email token expires
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# SMTP configuration options for the email service
# For testing, you can use a fake SMTP service like Ethereal: https://ethereal.email/create
SMTP_HOST=email-server
SMTP_PORT=587
SMTP_USERNAME=email-server-username
SMTP_PASSWORD=email-server-password
EMAIL_FROM=support@yourapp.com

# Backend public URL for candidate share links (must match the server that has the data)
# In production set to your API base, e.g. https://api.yourdomain.com
# If unset, defaults to http://localhost:PORT
# BACKEND_PUBLIC_URL=https://your-backend.example.com

# Frontend base URL for generating public job share links and email links
# Important: Update this to your production frontend URL when deploying
# If unset, defaults to http://localhost:3001
FRONTEND_BASE_URL=http://localhost:3001
# FRONTEND_BASE_URL=https://your-frontend.example.com

# LiveKit Configuration
# --- Option A: Local Docker ---
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=devsecret123456789012345678901234
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin123
# MINIO_BUCKET=recordings

# --- Option B: LiveKit Cloud (no Docker) ---
LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
LIVEKIT_API_KEY=your_api_key_from_cloud_project
LIVEKIT_API_SECRET=your_api_secret_from_cloud_project
# Recordings: use AWS S3 (set AWS credentials and bucket below)
LIVEKIT_S3_BUCKET=recordings

# MinIO (only for Option A)
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin123
# MINIO_BUCKET=recordings

# OpenAI – blog AI, module generation, and DALL-E cover images
OPENAI_API_KEY=

# GCP (YouTube + Gmail OAuth)
GCP_YOUTUBE_API_KEY=
GCP_GOOGLE_CLIENT_ID=
GCP_GOOGLE_CLIENT_SECRET=
GCP_GOOGLE_REDIRECT_URI=http://localhost:3000/v1/email/auth/google/callback


# Bolna Calling Configuration
# API key from Bolna dashboard
BOLNA_API_KEY=
# Agent ID from Bolna dashboard (default/general agent)
BOLNA_AGENT_ID=
# Agent ID for Job Application Verification calls (create separate agent for candidate calls)
BOLNA_CANDIDATE_AGENT_ID=
# Caller ID used for outbound calls (E.164 format, e.g. +18336990430)
BOLNA_FROM_PHONE_NUMBER=
# Optional fallback for caller ID (AddOn compatibility)
CALLER_ID=
# Bolna API base URL
BOLNA_API_BASE=https://api.bolna.ai

# RapidAPI key for External Jobs (Active Jobs DB / LinkedIn Jobs API)
RAPIDAPI_KEY=
